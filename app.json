{
  "expo": {
    "name": "GeoServit Express",
    "slug": "geoservit-express",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/icons/geoservit-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./src/assets/icons/geoservit-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F2B46"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.geoservit.express",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/icons/geoservit-icon.png",
        "backgroundColor": "#0F2B46"
      },
      "package": "com.anonymous.logisticav2"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "dbe61048-c25f-4066-b0cb-83e3d7b325e5"
      }
    }
  }
}
